# ============================================================================
# Environment Configuration Template
# Copy this file to .env and fill in YOUR values
# NEVER commit .env to git (already in .gitignore)
# ============================================================================

# ============================================================================
# HuggingFace Configuration (REQUIRED)
# ============================================================================
# Get token from: https://huggingface.co/settings/tokens
# 
# Steps:
# 1. Visit https://huggingface.co/settings/tokens
# 2. Click "New token"
# 3. Name it: "medgemma_project"
# 4. Select role: "read" (only needed for downloads)
# 5. Click "Create token"
# 6. Copy the value and paste below

HUGGINGFACE_TOKEN=hf_your_actual_token_here_XXXXXXXXXXXXXXXXXX


# ============================================================================
# Project Configuration
# ============================================================================
# Project root directory
PROJECT_ROOT=/home/shiftmint/Documents/kaggle/medAi_google

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO


# ============================================================================
# Model Configuration
# ============================================================================
# Model name to use
# Options: "google/medgemma-1.5-4b-it" (recommended, 4B params)
#          "google/medgemma-1.1-2b-it" (smaller, 2B params)
MODEL_NAME=google/medgemma-1.5-4b-it

# Inference parameters
TEMPERATURE=0.3              # 0.3 = deterministic (medical), 1.0 = creative
MAX_NEW_TOKENS=512          # Maximum response length

# Quantization for memory efficiency
USE_4BIT_QUANT=true         # Use 4-bit quantization (reduces VRAM by 75%)
QUANTIZATION_TYPE=nf4       # Use NF4 quantization format


# ============================================================================
# GPU Configuration
# ============================================================================
# GPU device selection
CUDA_DEVICE_ID=             # Leave empty = auto-detect, or: 0, 1, 2...

# Force CPU mode (for debugging or low-VRAM systems)
# FORCE_CPU=false

# ============================================================================
# Optional: Kaggle Configuration
# ============================================================================
# Only needed for Kaggle notebooks
# Get from: https://www.kaggle.com/settings/account

KAGGLE_USERNAME=
KAGGLE_KEY=
