# HuggingFace API Configuration
# ================================================
# Get your token at: https://huggingface.co/settings/tokens
# 
# Instructions:
# 1. Visit https://huggingface.co/settings/tokens
# 2. Click "New token"
# 3. Set Name: "medgemma_token" (or similar)
# 4. Set Role: "read" (this allows downloading models)
# 5. Click "Create token" and copy the value
# 6. Paste the value below replacing the placeholder
#
# SECURITY NOTE: NEVER commit .env to git!
# The .gitignore file already excludes it.

HUGGINGFACE_TOKEN=hf_your_actual_token_here_XXXXXXXXXXXXXXXXXX


# Optional: Kaggle API Configuration
# ================================================
# Only needed if running outside Kaggle notebooks
# Get credentials from: https://www.kaggle.com/settings/account

KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_key_here
